Rule 6     expression -> expression GT expression
Rule 7     expression -> expression EQ expression
Rule 8     expression -> NUMBER
Rule 9     expression -> ID
Rule 10    expression -> LPAREN expression RPAREN
Rule 11    expression -> IF expression THEN expression ELSE expression
Rule 12    statement -> expression SEMI
Rule 13    statement -> LET ID COLON INT_TYPE EQUALS expression SEMI

